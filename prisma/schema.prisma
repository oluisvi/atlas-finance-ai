model ImportItem {
  id                    String                 @id @default(uuid()) @db.Uuid
  importBatchId         String                 @map("import_batch_id") @db.Uuid
  userId                String                 @map("user_id") @db.Uuid
  accountId             String                 @map("account_id") @db.Uuid
  rowNumber             Int?                   @map("row_number")
  externalId            String?                @map("external_id") @db.VarChar(180)
  rawDescription        String                 @map("raw_description") @db.VarChar(255)
  normalizedDescription String?                @map("normalized_description") @db.VarChar(255)
  amount                Decimal                @db.Decimal(19, 4)
  inferredType          ImportItemInferredType @map("inferred_type")
  transactionDate       DateTime               @map("transaction_date") @db.Date
  postedAt              DateTime?              @map("posted_at") @db.Timestamptz(6)
  suggestedCategoryId   String?                @map("suggested_category_id") @db.Uuid
  matchedTransactionId  String?                @map("matched_transaction_id") @db.Uuid
  status                ImportItemStatus       @default(PENDING_REVIEW)
  fingerprint           String                 @db.VarChar(128)
  rawPayload            Json?                  @map("raw_payload")
  errorMessage          String?                @map("error_message") @db.Text
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  importBatch        ImportBatch  @relation(fields: [importBatchId], references: [id], onDelete: Restrict)
  user               User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  account            Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  suggestedCategory  Category?    @relation(fields: [suggestedCategoryId], references: [id], onDelete: Restrict)
  matchedTransaction Transaction? @relation("MatchedImportItem", fields: [matchedTransactionId], references: [id], onDelete: Restrict)
  createdTransaction Transaction? @relation("ImportedTransaction")

  @@unique([importBatchId, fingerprint])
  @@index([importBatchId, status])
  @@index([userId, fingerprint])
  @@index([matchedTransactionId])
  @@index([suggestedCategoryId])
  @@map("import_items")
}

