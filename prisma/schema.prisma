model FinancialScore {
  id                  String                       @id @default(uuid()) @db.Uuid
  userId              String                       @map("user_id") @db.Uuid
  periodStart         DateTime                     @map("period_start") @db.Date
  periodEnd           DateTime                     @map("period_end") @db.Date
  score               Int
  classification      FinancialScoreClassification
  savingsRate         Decimal?                     @map("savings_rate") @db.Decimal(9, 4)
  expenseRatio        Decimal?                     @map("expense_ratio") @db.Decimal(9, 4)
  emergencyFundMonths Decimal?                     @map("emergency_fund_months") @db.Decimal(9, 4)
  budgetAdherenceRate Decimal?                     @map("budget_adherence_rate") @db.Decimal(9, 4)
