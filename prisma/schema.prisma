model ImportBatch {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  accountId        String            @map("account_id") @db.Uuid
  sourceType       ImportSourceType  @map("source_type")
  originalFileName String            @map("original_file_name") @db.VarChar(255)
  fileHash         String            @map("file_hash") @db.VarChar(128)
  fileSizeBytes    Int               @map("file_size_bytes")
  status           ImportBatchStatus @default(UPLOADED)
  totalRows        Int?              @map("total_rows")
  parsedRows       Int?              @map("parsed_rows")
  importedRows     Int?              @map("imported_rows")
  duplicateRows    Int?              @map("duplicate_rows")
